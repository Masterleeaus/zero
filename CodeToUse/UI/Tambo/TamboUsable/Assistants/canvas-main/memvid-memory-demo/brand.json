{
  "name": "Memvid Canvas",
  "tagline": "AI-powered memory search",
  "theme": "system",
  "colors": {
    "primary": "#6366f1",
    "accent": "#8b5cf6",
    "success": "#10b981",
    "warning": "#f59e0b",
    "error": "#ef4444",
    "background": {
      "primary": "#ffffff",
      "secondary": "#f9fafb",
      "tertiary": "#f3f4f6"
    },
    "text": {
      "primary": "#111827",
      "secondary": "#4b5563",
      "muted": "#9ca3af"
    }
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "'SF Mono', Consolas, monospace",
    "fontSize": "14px"
  },
  "features": {
    "dashboard": false,
    "support": true,
    "search": true,
    "darkMode": true
  },
  "search": {
    "placeholder": "Search your memory...",
    "limit": 20,
    "showScores": true,
    "modes": ["semantic", "lexical", "hybrid"],
    "defaultMode": "hybrid",
    "enableFilters": true,
    "filters": [
      {
        "id": "type",
        "label": "Document Type",
        "type": "select",
        "options": ["All", "Documents", "Conversations", "Notes"]
      },
      {
        "id": "tags",
        "label": "Tags",
        "type": "tag",
        "options": ["important", "archived", "follow-up", "reviewed"]
      }
    ]
  },
  "support": {
    "agentName": "Canvas Assistant",
    "welcomeMessage": "Hi! I'm your AI assistant powered by Memvid memory. How can I help you today?",
    "suggestions": [
      "Search my documents",
      "Find recent conversations",
      "Help with setup",
      "Contact support"
    ],
    "enableTickets": true,
    "enableFeedback": true,
    "showSources": true,
    "inputPlaceholder": "Ask me anything..."
  },
  "dashboard": {
    "title": "Memory Analytics",
    "refreshInterval": 30000,
    "enableDateRange": true,
    "enableExport": true,
    "defaultTimeRange": "7d"
  }
}
