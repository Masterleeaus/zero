# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Zero"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_STATUS=
APP_DOMAIN=localhost # optional custom domain used by some tooling
ASSET_URL=/
MENU_CACHE_BY_USER_ID=false # cache menu tree per user ID
SHOW_LOAD_TIME=false # show request render time in UI footer
BCRYPT_ROUNDS=10
VIEW_COMPILED_PATH=

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_SLACK_WEBHOOK_URL=
LOG_STDERR_FORMATTER=null
LOG_PAPERTRAIL_HANDLER=Monolog\\Handler\\SyslogUdpHandler
PAPERTRAIL_URL=
PAPERTRAIL_PORT=

# ------------------------------------------------------------
# Localization
# ------------------------------------------------------------
LARAVELLOCALIZATION_UTF8SUFFIX=.UTF-8

# ------------------------------------------------------------
# Debugging & Tooling
# ------------------------------------------------------------
DEBUGBAR_ENABLED=false
DEBUGBAR_OPEN_STORAGE=false
DEBUGBAR_EDITOR=phpstorm
DEBUGBAR_REMOTE_SITES_PATH=
DEBUGBAR_LOCAL_SITES_PATH=
DEBUGBAR_THEME=auto
MINIFY_ENABLED=true
MINIFY_ASSETS_ENABLED=false
MINIFY_CSS_SEMICOLON=false
MINIFY_JS_SEMICOLON=false
MINIFY_REMOVE_COMMENTS=true
MINIFY_OBFUSCATE=true
TAILWIND_MERGE_PREFIX=
OCTANE_ENABLED=false
OCTANE_SERVER=roadrunner
OCTANE_HTTPS=false

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zero
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DATABASE_URL=
DB_FOREIGN_KEYS=true
MYSQL_ATTR_SSL_CA=
DB_ENCRYPT=
DB_TRUST_SERVER_CERTIFICATE=

# ------------------------------------------------------------
# Cache
# ------------------------------------------------------------
CACHE_DRIVER=file
CACHE_PREFIX=
DYNAMODB_CACHE_TABLE=cache
DYNAMODB_ENDPOINT=

# ------------------------------------------------------------
# Session
# ------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_CONNECTION=
SESSION_STORE=
SESSION_DOMAIN=
SESSION_COOKIE=
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=localhost

# ------------------------------------------------------------
# Queue / Jobs
# ------------------------------------------------------------
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids
REDIS_QUEUE=default
SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
SQS_QUEUE=default
SQS_SUFFIX=

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_PREFIX=
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ------------------------------------------------------------
# Memcached (optional)
# ------------------------------------------------------------
MEMCACHED_PERSISTENT_ID=
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# ------------------------------------------------------------
# Filesystems / Storage
# ------------------------------------------------------------
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_DEFAULT_REGION=us-east-1
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_URL=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------
# Mail
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_EHLO_DOMAIN=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_LOG_CHANNEL=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
POSTMARK_TOKEN=

# ------------------------------------------------------------
# Newsletter
# ------------------------------------------------------------
NEWSLETTER_DRIVER=Spatie\\Newsletter\\Drivers\\MailChimpDriver
NEWSLETTER_API_KEY=
NEWSLETTER_ENDPOINT=
NEWSLETTER_LIST_ID=

# ------------------------------------------------------------
# OAuth / Social Login & Captcha
# ------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_BUNDLE_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ------------------------------------------------------------
# AI Providers (configure at least one)
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_REQUEST_TIMEOUT=120
OPENAI_BASE_URL= # optional custom endpoint for OpenAI-compatible APIs
GEMINI_API_KEY=
GEMINI_REQUEST_TIMEOUT=30
DEEPSEEK_API_KEY=
DEEPSEEK_REQUEST_TIMEOUT=30

# ------------------------------------------------------------
# Broadcasting
# ------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
ABLY_KEY=

# ------------------------------------------------------------
# Payments & Billing
# ------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
CASHIER_PATH=stripe
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en
CASHIER_PAYMENT_NOTIFICATION=
CASHIER_INVOICE_RENDERER=Laravel\\Cashier\\Invoices\\DompdfInvoiceRenderer
CASHIER_PAPER=letter
CASHIER_LOGGER=
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_APP_ID=
PAYPAL_PAYMENT_ACTION=Sale
PAYPAL_CURRENCY=USD
PAYPAL_NOTIFY_URL=
PAYPAL_LOCALE=en_US
PAYPAL_VALIDATE_SSL=true
2CHECKOUT_MERCHANT_CODE=
2CHECKOUT_SECRET_KEY=
2CHECKOUT_PUBLISHABLE_KEY=
2CHECKOUT_PRIVATE_KEY=

# ------------------------------------------------------------
# Health & Monitoring
# ------------------------------------------------------------
HEALTH_SLACK_WEBHOOK_URL=
OH_DEAR_HEALTH_CHECK_SECRET=

# ------------------------------------------------------------
# Sentry (Error Tracking)
# ------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=local
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_SPOTLIGHT=false
SENTRY_BREADCRUMBS_LOGS_ENABLED=true
SENTRY_BREADCRUMBS_CACHE_ENABLED=true
SENTRY_BREADCRUMBS_LIVEWIRE_ENABLED=true
SENTRY_BREADCRUMBS_SQL_QUERIES_ENABLED=true
SENTRY_BREADCRUMBS_SQL_BINDINGS_ENABLED=false
SENTRY_BREADCRUMBS_QUEUE_INFO_ENABLED=true
SENTRY_BREADCRUMBS_COMMAND_JOBS_ENABLED=true
SENTRY_BREADCRUMBS_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_BREADCRUMBS_NOTIFICATIONS_ENABLED=true
SENTRY_TRACE_QUEUE_ENABLED=true
SENTRY_TRACE_QUEUE_JOBS_ENABLED=true
SENTRY_TRACE_SQL_QUERIES_ENABLED=true
SENTRY_TRACE_SQL_BINDINGS_ENABLED=false
SENTRY_TRACE_SQL_ORIGIN_ENABLED=true
SENTRY_TRACE_SQL_ORIGIN_THRESHOLD_MS=100
SENTRY_TRACE_VIEWS_ENABLED=true
SENTRY_TRACE_LIVEWIRE_ENABLED=true
SENTRY_TRACE_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_TRACE_CACHE_ENABLED=true
SENTRY_TRACE_REDIS_COMMANDS=false
SENTRY_TRACE_REDIS_ORIGIN_ENABLED=true
SENTRY_TRACE_NOTIFICATIONS_ENABLED=true
SENTRY_TRACE_MISSING_ROUTES_ENABLED=false
SENTRY_TRACE_CONTINUE_AFTER_RESPONSE=true
SENTRY_TRACE_DEFAULT_INTEGRATIONS_ENABLED=true

# ------------------------------------------------------------
# Mobile Apps
# ------------------------------------------------------------
MOBILE_APP_NAME="${APP_NAME}"
MOBILE_APP_DEVELOPER_NAME=
MOBILE_APP_PACKAGE_ID=com.example.app
MOBILE_APP_MAILTO=

# ------------------------------------------------------------
# MagicAI Updater / Licensing
# ------------------------------------------------------------
MAGICAI_USER_TYPE=customer # set to \"tester\" to consume the testing update feed
MAGICAI_LICENSE_KEY= # license key for MagicAI updates (if applicable)

# ------------------------------------------------------------
# Swagger / API Docs
# ------------------------------------------------------------
L5_SWAGGER_USE_ABSOLUTE_PATH=true
L5_FORMAT_TO_USE_FOR_DOCS=json
L5_SWAGGER_BASE_PATH=
L5_SWAGGER_CONST_HOST=http://my-default-host.com
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_GENERATE_YAML_COPY=false
L5_SWAGGER_OPEN_API_SPEC_VERSION=
L5_SWAGGER_OPERATIONS_SORT=
L5_SWAGGER_UI_ASSETS_PATH=vendor/swagger-api/swagger-ui/dist/
L5_SWAGGER_UI_DOC_EXPANSION=none
L5_SWAGGER_UI_FILTERS=true
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=false

